# =============================================================================
# Dune Awakening Self-Hosted Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server Identity
# -----------------------------------------------------------------------------
WORLD_NAME="My Dune Awakening Server"
WORLD_UNIQUE_NAME=sh-my-dune-server
WORLD_REGION=North America
WORLD_DATACENTER_ID=North America

# Funcom authentication token from https://account.duneawakening.com/
# Store in secrets/funcom-token.txt (preferred) or set here
FLS_SECRET=change-me-fls-secret

# FLS environment (retail for live servers, beta for public test)
DUNE_FLS_ENV=retail

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# Public IP or hostname for players to connect. Set to "auto" for automatic detection.
# "auto" resolves at container startup via api.ipify.org (requires outbound internet).
# If using a domain with Cloudflare DNS, set the record to "DNS only" (grey cloud) -
# Cloudflare's proxy drops UDP game traffic. See docs/NETWORKING.md for details.
EXTERNAL_ADDRESS=auto

# Host LAN IP (used by the host networking overlay for -MultiHome binding).
# Set this to your server's LAN IP when using host networking mode.
# HOST_LAN_IP=

# Host networking overlay: uncomment to run all game servers in network_mode: host,
# bypassing Docker bridge/iptables/veth entirely. Eliminates packet processing
# jitter that causes in-game rubberbanding on multi-map deployments.
# Requires HOST_LAN_IP to be set above.
# DUNE_HOSTNET_OVERLAY=docker-compose.hostnet-lean.yml

# -----------------------------------------------------------------------------
# Manual-update step hints (cosmetic  -  used by the dashboard's Updates page
# and the Discord update-available notification to fill in the "ssh user@host"
# command. Leave blank to show "<your-user>@<your-host>" placeholders.)
# -----------------------------------------------------------------------------
DUNE_SSH_USER=
DUNE_SSH_HOST=
DUNE_SERVER_DIR=~/dune-server-docker

# RabbitMQ public endpoint (must be reachable from player machines)
# "auto" resolves to the same IP as EXTERNAL_ADDRESS at gateway container startup.
# Set explicitly if your RMQ is behind a different IP/port than the game servers.
GAME_RMQ_PUBLIC_HOST=auto
GAME_RMQ_PUBLIC_PORT=31982
GAME_RMQ_PUBLIC_HTTP_PORT=31983
GAME_RMQ_BIND_ADDRESS=0.0.0.0

# Server display name (shown to players)
DUNE_SERVER_DISPLAY_NAME=

# Per-partition display names (override DUNE_SERVER_DISPLAY_NAME per map)
# Survival_1 is the open desert/PvP world; Overmap is the social hub
SURVIVAL_DISPLAY_NAME=Hagga Basin
OVERMAP_DISPLAY_NAME=Sietch Tabr

# World reset seed protection. Set to the seed your buildings were created under
# (typically 1) to stop "A storm has reset the map" from hiding bases on restart.
# When set, survival-pre-start.sh pins the seed before/after boot and the
# seed-guardian sidecar re-pins it every SEED_GUARD_INTERVAL seconds. Leave blank
# only for a brand-new world with no buildings to preserve.
SURVIVAL_RESET_SEED=1
SEED_GUARD_INTERVAL=300

# RMQ HTTP auth token (shared secret for internal auth)
RMQ_HTTP_TOKEN_AUTH_SECRET=change-me-rmq-http-token

# RMQ management credentials (optional, for admin tooling)
DUNE_RMQ_MANAGEMENT_USER=change-me-rmq-admin
DUNE_RMQ_MANAGEMENT_PASSWORD=change-me-rmq-management-password

# Game server port range start (UDP)
GAME_PORT_START=7777
# Server-to-server port range start (UDP)
S2S_PORT_START=7888

# -----------------------------------------------------------------------------
# Deployment Profile
# -----------------------------------------------------------------------------
# Options: basic (Survival+Overmap, ~20GB), standard-lean (+DeepDesert+social hubs, no story shards, ~30GB), standard (+DeepDesert+Story, ~30-40GB), full (all maps, ~40GB+)
DEPLOYMENT_PROFILE=basic

# Compose files used by the dashboard update pipeline (via COMPOSE_FILE env var)
# and Makefile. The `dune` CLI does NOT read COMPOSE_FILE — it derives compose
# paths from DEPLOYMENT_PROFILE and DUNE_HOSTNET_OVERLAY (see scripts/lib/common.sh).
# Keep COMPOSE_FILE in sync with DEPLOYMENT_PROFILE so dashboard-triggered updates
# recreate the same services as the original deployment.
COMPOSE_FILE=docker-compose.yml:docker-compose.basic.yml
#
# For standard-lean:
# DEPLOYMENT_PROFILE=standard-lean
# COMPOSE_FILE=docker-compose.yml:docker-compose.standard-lean.yml
#
# Legacy fallback only; COMPOSE_FILE is preferred.
# DUNE_COMPOSE_OVERLAY=basic

# Maps each game UDP port to the world map name its world_partition row is
# labeled with. Leave unset for the basic profile: partition_repair.py then uses
# its built-in default ({"7777":"Survival_1","7778":"Overmap"}). For the standard
# profile, uncomment the line below (it covers all nine map servers); keep it in
# sync with the -PartitionIndex / PARTITION_MAP_NAME wiring in the overlay.
# PARTITION_PORT_MAP='{"7777":"Survival_1","7778":"Overmap","7779":"DeepDesert_1","7780":"SH_Arrakeen","7781":"SH_HarkoVillage","7782":"CB_Story_Hephaestus","7783":"CB_Story_Ecolab_Carthag","7784":"CB_Story_WaterFatManor","7785":"Story_ProcesVerbal"}'
#
# For standard-lean (5 maps, no story shards):
# PARTITION_PORT_MAP='{"7777":"Survival_1","7778":"Overmap","7779":"DeepDesert_1","7780":"SH_Arrakeen","7781":"SH_HarkoVillage"}'

# Anti-thrash cooldown (seconds) the game-server entrypoint waits before relaunching
# after the server process exits, to avoid a tight crash-restart loop. Default 15.
# RESTART_COOLDOWN_SECONDS=15
# Wait for a released UDP game port before launching the game binary after a
# container recreate. This is the main mitigation for the old-socket bind race.
# Default 30.
# PORT_AVAILABILITY_WAIT_SECONDS=30

# -----------------------------------------------------------------------------
# Docker Image Configuration
# -----------------------------------------------------------------------------
# Image tag from Funcom's Steam package (updated by `dune update`)
# Funcom game server image tag (pin to a specific version for reproducibility)
# Find tags at: docker pull funcom/self-hosting/seabass-server:<tag>
DUNE_IMAGE_TAG=2007976-0-shipping

# Steam App ID for server downloads
STEAM_APP_ID=4754530

# Path to Steam server files (where tarballs are extracted)
DUNE_STEAM_SERVER_DIR=./steam

# Update checking configuration
UPDATE_CHECK_INTERVAL_HOURS=6
UPDATE_AUTO_UPDATE=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_SUPER_PASSWORD=change-me-postgres-super
POSTGRES_DUNE_PASSWORD=change-me-dune-db
POSTGRES_PORT=15432

# Game database name. The Funcom binary otherwise derives this from its build
# branch (e.g. dune_sb_1_4_5_0), but existing save data lives in dune_sb_1_4_0_0,
# so the compose files pin DatabaseName to this value. Override only if your save
# data lives in a differently named database. Default: dune_sb_1_4_0_0.
# POSTGRES_DB_NAME=dune_sb_1_4_0_0

# -----------------------------------------------------------------------------
# Dashboard Configuration
# -----------------------------------------------------------------------------
# Admin authentication token for the dashboard API
DUNE_ADMIN_TOKEN=change-me-admin-token

# Require auth token for read (GET) requests too (true = all endpoints need token)
DUNE_ADMIN_READ_AUTH=true

# Enable dangerous mutations (currency/XP/item grants)
DUNE_ADMIN_MUTATIONS_ENABLED=false

# Dashboard internal database (default: SQLite in the persistent volume)
# Override only if you want an external DB. Set in docker-compose.yml by default.
# DUNE_DASHBOARD_DB_URL=sqlite+aiosqlite:////workspace/data/dashboard.db

# Dashboard bind address (127.0.0.1 = local only, 0.0.0.0 = LAN accessible)
DUNE_ADMIN_BIND_ADDRESS=127.0.0.1
DUNE_ADMIN_HOST_PORT=18080

# -----------------------------------------------------------------------------
# Watchdog (resource pressure + crash-loop alerting)
# -----------------------------------------------------------------------------
# CPU pressure alert threshold, % (>100 means multi-core). Default 175 fits a
# 2-core (200%) capped game-server container  -  alerts at ~87% of allocation.
# WATCHDOG_CPU_WARN_PCT=175
# Memory pressure alert threshold, % of container limit.
# WATCHDOG_MEM_WARN_PCT=85
# Skip CPU/memory alerts for this many seconds after a container starts.
# Game-server containers spike during initialization (world load, NPC spawn,
# replication graph build). Default 180s (3 minutes).
# WATCHDOG_RESOURCE_WARM_UP_SECONDS=180
# Require this many consecutive over-threshold polls before alerting. With a
# 30s poll interval, the default of 3 means a service must be over-threshold
# for ~90s. Single spikes will not trigger alerts.
# WATCHDOG_RESOURCE_SUSTAINED_SAMPLES=3
# Per-alert cooldown, seconds. Default 300 (5 minutes).
# WATCHDOG_ALERT_COOLDOWN=300
# Auto-clear orphaned ("ghost") RabbitMQ connections left by dropped game sessions
# that cause "Error: P83" on map travel. Disabled by default: clearing connections
# during travel can stop the S2S peer index from converging. Enable only if you see
# persistent P83 and understand the trade-off (or run `dune fix-p83 --apply`).
# WATCHDOG_RMQ_GHOST_CLEANUP=false

# Allowed origins for CORS
DUNE_ADMIN_ALLOWED_HOSTS=127.0.0.1:18080,localhost:18080

# Frontend API base URL (used by Next.js at build time; leave blank for same-origin)
# NEXT_PUBLIC_API_BASE_URL=http://your-server-ip:18080

# -----------------------------------------------------------------------------
# Discord Webhooks (optional)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=change-me-discord-webhook
DISCORD_NOTIFY_START=true
DISCORD_NOTIFY_STOP=true
DISCORD_NOTIFY_CRASH=true
DISCORD_NOTIFY_PLAYER_JOIN=false
DISCORD_NOTIFY_PLAYER_LEAVE=false

# -----------------------------------------------------------------------------
# In-game Announcements (optional)
# -----------------------------------------------------------------------------
DUNE_ANNOUNCE_ENABLED=true
DUNE_ANNOUNCE_NAME="Muad'Dib"
# Announcer AMQP account: must be a 16-hex-char "player" ID registered in the
# game database via dune.login_account(). The auth-shim accepts these without
# password checks. user_id in published messages must match this value.
DUNE_ANNOUNCE_CHAT_USER=A000000000000001
DUNE_ANNOUNCE_CHAT_PASSWORD=announce
# Routing keys for chat.map (comma-separated, empty value = empty routing key)
DUNE_ANNOUNCE_ROUTING_KEYS=,Survival_1.dim_0,HaggaBasin.0

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_DIR=./backups
# Keep this many newest backup artifacts regardless of age.
BACKUP_KEEP_N=14
# Delete backup artifacts older than this many days only when they are not in the newest BACKUP_KEEP_N.
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# Chat Spam Protection
# -----------------------------------------------------------------------------
DUNE_CHAT_GUARD_ENABLED=true
DUNE_CHAT_MAX_CONSECUTIVE=3
DUNE_CHAT_RATE_WINDOW=10
DUNE_CHAT_RATE_MAX=5
DUNE_CHAT_AUTO_KICK=false

# -----------------------------------------------------------------------------
# Memory Limits (per container)
# -----------------------------------------------------------------------------
MEM_LIMIT_SURVIVAL=16g
MEM_LIMIT_OVERMAP=3g
MEM_LIMIT_DEEP_DESERT=16g
MEM_LIMIT_DEFAULT_MAP=3g
MEM_LIMIT_TESTING_MAP=2g
MEM_LIMIT_POSTGRES=2g
MEM_LIMIT_RMQ=1g
MEM_LIMIT_DIRECTOR=512m
MEM_LIMIT_TEXT_ROUTER=256m
MEM_LIMIT_GATEWAY=256m

# CPU Limits (per container, in CPU cores)
# -----------------------------------------------------------------------------
CPU_LIMIT_SURVIVAL=4
CPU_LIMIT_OVERMAP=2

# -----------------------------------------------------------------------------
# Login Password (optional - restricts who can join)
# -----------------------------------------------------------------------------
DUNE_SERVER_LOGIN_PASSWORD=change-me-login-password

# -----------------------------------------------------------------------------
# Authentication Secrets (auto-generated if blank)
# These secrets must match across director, text-router, and game servers
# to authenticate player logins. Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
DUNE_SERVER_LOGIN_PASSWORD_SECRET=
DUNE_USERNAME_SERVER_LOGIN_SECRET=
DUNE_LOGIN_PASSWORD_SKEW_SECONDS=300

# FLS API key (auto-generated if blank). Generate with: openssl rand -hex 16
FLS_APIKEY=

# -----------------------------------------------------------------------------
# Docker Network (advanced - DO NOT change unless 10.80.0.0/20 conflicts with
# your LAN). The compose files use hardcoded static IPs (10.80.0.x) for service
# discovery, so changing this subnet without updating all ipv4_address entries
# and hostnet overlay extra_hosts will break container startup.
# -----------------------------------------------------------------------------
# DUNE_DOCKER_SUBNET=10.80.0.0/20
