# =============================================================================
# Dune Awakening Self-Hosted Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server Identity
# -----------------------------------------------------------------------------
WORLD_NAME="My Dune Awakening Server"
WORLD_UNIQUE_NAME=sh-my-dune-server
WORLD_REGION=North America
WORLD_DATACENTER_ID=North America

# Funcom authentication token from https://account.duneawakening.com/
# Store in secrets/funcom-token.txt (preferred) or set here
FLS_SECRET=change-me-fls-secret

# FLS environment (beta for public test, retail for live)
DUNE_FLS_ENV=beta

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# Public IP address for players to connect. Set to "auto" for automatic detection.
EXTERNAL_ADDRESS=auto

# RabbitMQ public endpoint (must be reachable from player machines)
GAME_RMQ_PUBLIC_HOST=auto
GAME_RMQ_PUBLIC_PORT=31982
GAME_RMQ_PUBLIC_HTTP_PORT=31983
GAME_RMQ_BIND_ADDRESS=0.0.0.0

# Server display name (shown to players)
DUNE_SERVER_DISPLAY_NAME=

# RMQ HTTP auth token (shared secret for internal auth)
RMQ_HTTP_TOKEN_AUTH_SECRET=change-me-rmq-http-token

# RMQ management credentials (optional, for admin tooling)
DUNE_RMQ_MANAGEMENT_USER=change-me-rmq-admin
DUNE_RMQ_MANAGEMENT_PASSWORD=change-me-rmq-management-password

# Game server port range start (UDP)
GAME_PORT_START=7777
# Server-to-server port range start (UDP)
S2S_PORT_START=7888

# -----------------------------------------------------------------------------
# Deployment Profile
# -----------------------------------------------------------------------------
# Options: basic (Survival+Overmap, ~20GB), standard (+DeepDesert+Story, ~30-40GB), full (all maps, ~40GB+)
DEPLOYMENT_PROFILE=basic

# -----------------------------------------------------------------------------
# Docker Image Configuration
# -----------------------------------------------------------------------------
# Image tag from Funcom's Steam package (updated by `dune update`)
DUNE_IMAGE_TAG=latest

# Steam App ID for server downloads
STEAM_APP_ID=3104830

# Path to Steam server files (where tarballs are extracted)
DUNE_STEAM_SERVER_DIR=./steam

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_SUPER_PASSWORD=change-me-postgres-super
POSTGRES_DUNE_PASSWORD=change-me-dune-db
POSTGRES_PORT=15432

# -----------------------------------------------------------------------------
# Dashboard Configuration
# -----------------------------------------------------------------------------
# Admin authentication token for the dashboard API
DUNE_ADMIN_TOKEN=change-me-admin-token

# Enable dangerous mutations (currency/XP/item grants)
DUNE_ADMIN_MUTATIONS_ENABLED=false

# Dashboard bind address (127.0.0.1 = local only, 0.0.0.0 = LAN accessible)
DUNE_ADMIN_BIND_ADDRESS=127.0.0.1
DUNE_ADMIN_HOST_PORT=18080

# Allowed origins for CORS
DUNE_ADMIN_ALLOWED_HOSTS=127.0.0.1:18080,localhost:18080

# -----------------------------------------------------------------------------
# Discord Webhooks (optional)
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=change-me-discord-webhook
DISCORD_NOTIFY_START=true
DISCORD_NOTIFY_STOP=true
DISCORD_NOTIFY_CRASH=true
DISCORD_NOTIFY_PLAYER_JOIN=false
DISCORD_NOTIFY_PLAYER_LEAVE=false

# -----------------------------------------------------------------------------
# In-game Announcements (optional)
# -----------------------------------------------------------------------------
DUNE_ANNOUNCE_ENABLED=true
DUNE_ANNOUNCE_NAME=Server

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_INTERVAL_HOURS=24

# -----------------------------------------------------------------------------
# Chat Spam Protection
# -----------------------------------------------------------------------------
DUNE_CHAT_GUARD_ENABLED=true
DUNE_CHAT_MAX_CONSECUTIVE=3
DUNE_CHAT_RATE_WINDOW=10
DUNE_CHAT_RATE_MAX=5
DUNE_CHAT_AUTO_KICK=false

# -----------------------------------------------------------------------------
# Memory Limits (per container)
# -----------------------------------------------------------------------------
MEM_LIMIT_SURVIVAL=12g
MEM_LIMIT_OVERMAP=2g
MEM_LIMIT_DEEP_DESERT=10g
MEM_LIMIT_DEFAULT_MAP=8g
MEM_LIMIT_POSTGRES=1g
MEM_LIMIT_RMQ=512m
MEM_LIMIT_DIRECTOR=512m
MEM_LIMIT_TEXT_ROUTER=256m
MEM_LIMIT_GATEWAY=256m

# -----------------------------------------------------------------------------
# Login Password (optional - restricts who can join)
# -----------------------------------------------------------------------------
DUNE_SERVER_LOGIN_PASSWORD=change-me-login-password

# -----------------------------------------------------------------------------
# Docker Network (advanced - change only if 10.80.0.0/20 conflicts with your LAN)
# -----------------------------------------------------------------------------
# DUNE_DOCKER_SUBNET=10.80.0.0/20
